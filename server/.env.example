# ========================================================
# Varta Assistant Environment Configuration
# Copy this file to '.env' inside the 'server/' directory
# ========================================================

# The port the backend server runs on
PORT=5000

# MongoDB Connection String (Atlas or Local)
# For Atlas, replace with your mongodb+srv:// connection URI
MONGO_URI=mongodb://127.0.0.1:27017/varta_assistant

# Groq API Credentials
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Admin Portal Password Gate
# Used by the frontend JS prompt dialog to unlock the analytics page
ADMIN_PASSWORD=varta123
